SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
ANTHROPIC_API_KEY=sk-ant-your-key

# Jira MCP server URL (Atlassian hosted or self-hosted)
JIRA_MCP_URL=https://mcp.atlassian.com/v1/sse

# Jira OAuth 2.0 — create app at https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=your-jira-oauth-client-id
JIRA_CLIENT_SECRET=your-jira-oauth-client-secret
JIRA_REDIRECT_URI=https://your-server.example.com/auth/jira/callback

# SQLite path (inside container, mount a volume here)
DB_PATH=data/chatbot.db
